# LinkVerse Analytics — Environment Template
# Copy to .env and replace placeholders. Never commit .env.

# JWT shared secret (Gateway + Auth). Use: openssl rand -base64 32
JWT_SECRET=TpcfFSeH4vECOAX8Sb37k40AY7nbcjp9vHD8uP53nie

# PostgreSQL
DB_PASSWORD=replace_with_db_password
DB_USER=linkverse
DB_NAME=linkverse
POSTGRES_DSN=postgres://linkverse:replace_with_db_password@postgres:5432/linkverse

# Redis
REDIS_ADDR=redis:6379

# Internal service URLs (Docker network hostnames)
AUTH_SERVICE_URL=http://auth-service:8081
LINK_SERVICE_URL=http://link-service:8082
ANALYTICS_SERVICE_URL=http://analytics-service:8083
REPORT_SERVICE_URL=http://report-service:8084

# GeoIP database path (inside analytics-service container)
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb
